<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="650.0" prefWidth="800.0" spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controller.MainController">
    <children>
        <Label text="Edituri (Părinte)" style="-fx-font-weight: bold; -fx-font-size: 14px;" />

        <TableView fx:id="tableEdituri" prefHeight="200.0">
            <columns>
                <TableColumn fx:id="colIdEditura" prefWidth="75.0" text="ID" />
                <TableColumn fx:id="colNumeEditura" prefWidth="300.0" text="Nume Editură" />
            </columns>
        </TableView>

        <Separator prefWidth="200.0" />

        <Label text="Cărți în Editura Selectată (Copil)" style="-fx-font-weight: bold; -fx-font-size: 14px;" />

        <TableView fx:id="tableCarti" prefHeight="200.0">
            <columns>
                <TableColumn fx:id="colIdCarte" prefWidth="75.0" text="ID" />
                <TableColumn fx:id="colTitluCarte" prefWidth="250.0" text="Titlu" />
                <TableColumn fx:id="colAnCarte" prefWidth="100.0" text="An Apariție" />
                <TableColumn fx:id="colIsbnCarte" prefWidth="150.0" text="ISBN" />
            </columns>
        </TableView>

        <GridPane hgap="10.0" vgap="10.0">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <columnConstraints>
                <ColumnConstraints minWidth="100.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>
            <children>
                <Label text="Titlu:" />
                <TextField fx:id="txtTitlu" GridPane.columnIndex="1" />

                <Label text="An Apariție:" GridPane.rowIndex="1" />
                <TextField fx:id="txtAn" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="ISBN:" GridPane.rowIndex="2" />
                <TextField fx:id="txtIsbn" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            </children>
        </GridPane>

        <HBox alignment="CENTER" spacing="20.0">
            <children>
                <Button fx:id="btnAdd" mnemonicParsing="false" onAction="#handleAddCarte" prefWidth="80.0" text="Adauga" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" />
                <Button fx:id="btnUpdate" mnemonicParsing="false" onAction="#handleUpdateCarte" prefWidth="80.0" text="Modifica" style="-fx-background-color: #2196F3; -fx-text-fill: white;" />
                <Button fx:id="btnDelete" mnemonicParsing="false" onAction="#handleDeleteCarte" prefWidth="80.0" text="Sterge" style="-fx-background-color: #f44336; -fx-text-fill: white;" />
                <Button text="Ruleaza Test Performanta" onAction="#handleTestPerformanta"
                        style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;"/>
                <Button text="Leak Demo" onAction="#handleLeakDemo"
                        style="-fx-background-color: #4c54af; -fx-text-fill: white; -fx-font-weight: bold;"/>
            </children>
            <VBox.margin>
                <Insets bottom="10.0" />
            </VBox.margin>
        </HBox>
    </children>
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>
</VBox>